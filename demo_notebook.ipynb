   "source": [
    "# state-est-testbed Live Demo\n",
    "**Simulation-based R&D framework for state estimators and predictors**\n",
    "\n",
    "This notebook demonstrates Monte-Carlo evaluation of a Kalman Filter on a realistic maneuvering target trajectory generated by `simple.py`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 1. Setup & Imports\n",
    "import sys\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from tqdm import tqdm\n",
    "\n",
    "import stateest\n",
    "\n",
    "print('stateest version:', getattr(stateest, '__version__', 'unknown'))\n",
    "print('Working directory:', __import__('os').getcwd())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 2. Load Trajectory Data\n",
    "df = pd.read_csv('maneuver_kalman_test_data.csv')\n",
    "\n",
    "print(f\"Loaded trajectory with {len(df)} timesteps\")\n",
    "print(f\"Altitude range: {df['true_z_m'].min()/1000:.2f} – {df['true_z_m'].max()/1000:.2f} km\")\n",
    "print(f\"Max lateral displacement: {df['true_y_m'].abs().max():.0f} m\")\n",
    "\n",
    "# Full 6D truth state (position + velocity)\n",
    "x_true = np.hstack([\n",
    "    df[['true_x_m', 'true_y_m', 'true_z_m']].values,\n",
    "    df[['true_vx_mps', 'true_vy_mps', 'true_vz_mps']].values\n",
    "])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 3. Define Simple Constant-Velocity Kalman Filter\n",
    "dt = df['time_s'].diff().mean()\n",
    "\n",
    "# 6D state: [px, py, pz, vx, vy, vz]\n",
    "F = np.eye(6)\n",
    "F[0:3, 3:6] = dt * np.eye(3)\n",
    "\n",
    "Q = np.diag([0, 0, 0, 0.5, 0.5, 0.5])                    # process noise\n",
    "R = np.diag([15**2, 15**2, 15**2, 1.5**2, 0.1**2, 0.1**2])  # measurement noise\n",
    "\n",
    "H = np.eye(6)   # placeholder (we'll improve this later with real measurement model)\n",
    "\n",
    "print(f\"State transition matrix F shape: {F.shape}\")\n",
    "print(f\"Process noise Q diagonal: {np.diag(Q)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# 4. Run Monte-Carlo Simulation (100 runs)\n",
    "n_mc = 100\n",
    "rmse_pos_list = []\n",
    "rmse_vel_list = []\n",
    "nees_list = []\n",
    "\n",
    "for run in tqdm(range(n_mc), desc=\"Monte-Carlo runs\"):\n",
    "    kf = stateest.KalmanFilter(F, Q, H, R)\n",
    "    \n",
    "    # Initial state\n",
    "    x0 = np.array([800000., 0., 80000., -5500., 0., -30.])\n",
    "    P0 = np.diag([1000**2]*3 + [200**2]*3)\n",
    "    kf.init(x0, P0)\n",
    "    \n",
    "    estimates = []\n",
    "    \n",
    "    for i in range(len(df)):\n",
    "        kf.predict()\n",
    "        \n",
    "        # Fake measurement for now (using truth + noise)\n",
    "        z = x_true[i] + np.random.randn(6) * np.sqrt(np.diag(R))\n",
    "        \n",
    "        kf.update(z)\n",
    "        estimates.append(kf.state.copy())\n",
    "    \n",
    "    estimates = np.array(estimates)\n",
    "    \n",
    "    # Compute metrics\n",
    "    rmse_pos = np.sqrt(np.mean((estimates[:, :3] - x_true[:, :3])**2, axis=0)).mean()\n",
    "    rmse_vel = np.sqrt(np.mean((estimates[:, 3:] - x_true[:, 3:])**2, axis=0)).mean()\n",
    "    \n",
    "    # Final NEES\n",
    "    final_err = estimates[-1
